<Window x:Class="LaptopShop.WPF.Login"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:LaptopShop.WPF"
        mc:Ignorable="d"
        Title="Login" Height="450" Width="800">
    <Grid>

        <Label Content="UserName :" HorizontalAlignment="Left" Margin="181,89,0,0" VerticalAlignment="Top" Height="23" Width="74"/>
        <Label Content="Password :" HorizontalAlignment="Left" Margin="181,135,0,0" VerticalAlignment="Top" Height="23" Width="74"/>
        <TextBox x:Name="txtUserName" HorizontalAlignment="Left" Margin="270,92,0,0" TextWrapping="Wrap" Text="" VerticalAlignment="Top" Width="157"/>
        <PasswordBox x:Name="pwdPassword" HorizontalAlignment="Left" Margin="270,138,0,0" VerticalAlignment="Top" Width="157"/>
        <Button x:Name="btnLogin" Content="Login" HorizontalAlignment="Left" Margin="270,182,0,0" VerticalAlignment="Top" Height="20" Width="68" Click="btnLogin_Click"/>
        <Button x:Name="btnRegister" Content="Register" HorizontalAlignment="Left" Margin="359,182,0,0" VerticalAlignment="Top" Height="20" Width="68" Click="btnRegister_Click"/>
        <Label Content="WellCome To LaptopShop" HorizontalAlignment="Left" Margin="270,18,0,0" VerticalAlignment="Top"/>


    </Grid>
</Window>
