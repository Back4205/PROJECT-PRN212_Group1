<Window x:Class="LaptopShop.WPF.Login"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Laptop Shop - Login" Height="450" Width="800"
        WindowStartupLocation="CenterScreen" WindowStyle="None" AllowsTransparency="True" Background="Transparent">

    <Border CornerRadius="20" Background="White">
        <Border.Effect>
            <DropShadowEffect BlurRadius="20" Color="#EEEEEE" ShadowDepth="2"/>
        </Border.Effect>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="350"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" CornerRadius="20,0,0,20">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#2193b0" Offset="0"/>
                        <GradientStop Color="#6dd5ed" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <TextBlock Text="LAPTOP SHOP" Foreground="White" FontSize="28" FontWeight="Bold" HorizontalAlignment="Center"/>
                    <TextBlock Text="Premium Experience" Foreground="White" FontSize="14" Opacity="0.8" HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>

            <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="50,0">
                <TextBlock Text="Đăng Nhập" FontSize="26" FontWeight="SemiBold" Foreground="#333" Margin="0,0,0,30"/>

                <TextBlock Text="Tên đăng nhập" Foreground="#888" Margin="0,0,0,5"/>
                <Border BorderBrush="#DDD" BorderThickness="0,0,0,1" Margin="0,0,0,20">
                    <TextBox x:Name="txtUserName" BorderThickness="0" FontSize="14" Padding="5" Background="Transparent"/>
                </Border>

                <TextBlock Text="Mật khẩu" Foreground="#888" Margin="0,0,0,5"/>
                <Border BorderBrush="#DDD" BorderThickness="0,0,0,1" Margin="0,0,0,30">
                    <PasswordBox x:Name="pwdPassword" BorderThickness="0" FontSize="14" Padding="5" Background="Transparent"/>
                </Border>

                <Button x:Name="btnLogin" Content="LOGIN" Height="40" Background="#2193b0" Foreground="White" FontWeight="Bold" Cursor="Hand" Click="btnLogin_Click">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="20"/>
                        </Style>
                    </Button.Resources>
                </Button>

                <Button x:Name="btnRegister" Content="Chưa có tài khoản? Đăng ký ngay" Background="Transparent" BorderThickness="0" Foreground="#2193b0" Margin="0,15,0,0" Cursor="Hand" Click="btnRegister_Click"/>

               
            </StackPanel>
        </Grid>
    </Border>
</Window>