<Window x:Class="LaptopShop.WPF.Register"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Laptop Shop - Register" Height="600" Width="450"
        WindowStartupLocation="CenterScreen" WindowStyle="None" AllowsTransparency="True" Background="Transparent">

    <Border CornerRadius="20" Background="White">
        <Border.Effect>
            <DropShadowEffect BlurRadius="20" Color="#CCCCCC" ShadowDepth="2"/>
        </Border.Effect>

        <Grid Margin="30">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Margin="0,0,0,20">
                <TextBlock Text="TẠO TÀI KHOẢN" FontSize="24" FontWeight="Bold" Foreground="#2193b0" HorizontalAlignment="Center"/>
                <TextBlock Text="Laptop Shop" Foreground="Gray" FontSize="12" HorizontalAlignment="Center" Margin="0,5,0,0"/>
            </StackPanel>

            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="10,0">

                    <TextBlock Text="Tên đăng nhập" Foreground="#555" Margin="0,10,0,5"/>
                    <Border BorderBrush="#DDD" BorderThickness="1" CornerRadius="5" Padding="5">
                        <TextBox x:Name="txtUserName" BorderThickness="0" VerticalAlignment="Center"/>
                    </Border>

                    <TextBlock Text="Họ và tên" Foreground="#555" Margin="0,10,0,5"/>
                    <Border BorderBrush="#DDD" BorderThickness="1" CornerRadius="5" Padding="5">
                        <TextBox x:Name="txtFullname" BorderThickness="0" VerticalAlignment="Center"/>
                    </Border>

                    <TextBlock Text="Email" Foreground="#555" Margin="0,10,0,5"/>
                    <Border BorderBrush="#DDD" BorderThickness="1" CornerRadius="5" Padding="5">
                        <TextBox x:Name="txtEmail" BorderThickness="0" VerticalAlignment="Center"/>
                    </Border>

                    <TextBlock Text="Số điện thoại" Foreground="#555" Margin="0,10,0,5"/>
                    <Border BorderBrush="#DDD" BorderThickness="1" CornerRadius="5" Padding="5">
                        <TextBox x:Name="txtPhoneNumber" BorderThickness="0" VerticalAlignment="Center"/>
                    </Border>

                    <TextBlock Text="Mật khẩu" Foreground="#555" Margin="0,10,0,5"/>
                    <Border BorderBrush="#DDD" BorderThickness="1" CornerRadius="5" Padding="5">
                        <PasswordBox x:Name="pwdPassword" BorderThickness="0" VerticalAlignment="Center"/>
                    </Border>

                    <TextBlock Text="Xác nhận mật khẩu" Foreground="#555" Margin="0,10,0,5"/>
                    <Border BorderBrush="#DDD" BorderThickness="1" CornerRadius="5" Padding="5">
                        <PasswordBox x:Name="pwdConfirmPassword" BorderThickness="0" VerticalAlignment="Center"/>
                    </Border>

                </StackPanel>
            </ScrollViewer>

            <Button Grid.Row="2" x:Name="btnRegister" Content="ĐĂNG KÝ NGAY" 
                    Height="45" Margin="10,20,10,10" FontWeight="Bold" Foreground="White" 
                    Cursor="Hand" Click="btnRegister_Click">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Background" Value="#2193b0"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" CornerRadius="22">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Button.Style>
            </Button>

            <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10,0,0">
                <Button Content="Đã có tài khoản? Đăng nhập" Background="Transparent" BorderThickness="0" Foreground="#2193b0" Cursor="Hand" Click="BackToLogin_Click"/>
                <TextBlock Text=" | " Foreground="#DDD" VerticalAlignment="Center"/>
                <Button Content="Thoát" Background="Transparent" BorderThickness="0" Foreground="Gray" Cursor="Hand" Click="Close_Click"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>